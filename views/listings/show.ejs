<% layout('layouts/boilerplate') %>
<article class="show-page">
    <img class="show-image"
        src="<%= listing.image.url %>"
        alt="<%= listing.title %>"
    >

    <div class="show-content">
        <h1><%= listing.title %></h1>

        <div class="listing-meta">
            <% if (listing.owner) { %>
                <span class="meta-item">
                    <i class="fa-solid fa-user"></i>
                    <%= listing.owner.username %>
                </span>
                <span class="meta-item">
                    <i class="fa-solid fa-envelope"></i>
                    <%= listing.owner.email %>
                </span>
            <% } %>
            <% if (listing.createdAt) { %>
                <span class="meta-item">
                    <i class="fa-solid fa-calendar-days"></i>
                    Posted <%= listing.createdAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
            <% } %>
            <% if (listing.updatedAt && listing.createdAt && listing.updatedAt.getTime() !== listing.createdAt.getTime()) { %>
                <span class="meta-item">
                    <i class="fa-solid fa-pen"></i>
                    Updated <%= listing.updatedAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
            <% } %>
            <span class="meta-item meta-rating">
                <i class="fa-solid fa-star"></i>
                <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <%= (listing.reviews.reduce((sum, review) => sum + review.rating, 0) / listing.reviews.length).toFixed(1) %>
                    <span class="meta-rating-count">(<%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? "s" : "" %>)</span>
                <% } else { %>
                    No reviews yet
                <% } %>
            </span>
        </div>

        <p class="description"><%= listing.description %></p>
        <p class="price">&#8377; <%= listing.price.toLocaleString('en-IN') %> <span class="price-unit">per night</span></p>
        <p class="muted"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>

        <% if (currentUser) { %>
            <form method="POST" action="/listings/<%= listing._id %>/wishlist" style="margin:10px 0;">
                <button class="btn <%= isWishlisted ? 'danger' : '' %>" type="submit">
                    <i class="fa-solid fa-heart"></i>
                    <%= isWishlisted ? "Remove from Wishlist" : "Add to Wishlist" %>
                </button>
            </form>
        <% } %>

        <% if (listing.deleted) { %>
            <div class="listing-meta" style="border-bottom:none; margin-bottom:0;">
                <span class="meta-item" style="background:#fee2e2; border-color:var(--danger); color:var(--danger-dark);">
                    <i class="fa-solid fa-trash"></i>
                    This listing is in trash — <a href="/listings/trash" style="text-decoration:underline;">restore it</a> to make changes
                </span>
            </div>
        <% } else if (currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
        <div class="actions">
            <a class="btn" href="/listings/<%= listing._id %>/edit">Edit this listing</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn danger" type="submit">Delete this listing</button>
            </form>
        </div>
        <% } %>

        <% if (!listing.deleted) { %>
        <div class="review-section">
            <h3>Leave a Review</h3>
            <form method="POST" action="/listings/<%= listing._id %>/reviews" class="review-form">
                <div class="star-rating">
                    <input type="radio" id="star5" name="review[rating]" value="5">
                    <label for="star5">&#9733;</label>
                    <input type="radio" id="star4" name="review[rating]" value="4">
                    <label for="star4">&#9733;</label>
                    <input type="radio" id="star3" name="review[rating]" value="3">
                    <label for="star3">&#9733;</label>
                    <input type="radio" id="star2" name="review[rating]" value="2">
                    <label for="star2">&#9733;</label>
                    <input type="radio" id="star1" name="review[rating]" value="1">
                    <label for="star1">&#9733;</label>
                </div>

                <div class="form-group">
                    <label for="comment">Comment</label>
                    <textarea
                        id="comment"
                        name="review[comment]"
                        rows="3"
                        placeholder="Share your experience..."
                    ></textarea>
                </div>

                <button class="btn" type="submit">Submit Review</button>
            </form>

            <h3>All Reviews</h3>
            <% if (listing.reviews && listing.reviews.length > 0) { %>
                <div class="reviews-list">
                    <% listing.reviews.forEach(review => { %>
                        <div class="review-card">
                            <div class="review-meta">
                                <span class="review-author"><i class="fa-solid fa-user"></i> <%= review.author %></span>
                                <% if (review.createdAt) { %>
                                    <span class="review-date">
                                        <%= review.createdAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    </span>
                                <% } %>
                            </div>

                            <div class="review-view" id="view-<%= review._id %>">
                                <p class="review-rating">
                                    <% for (let i = 0; i < review.rating; i++) { %>&#9733;<% } %>
                                    <% for (let i = review.rating; i < 5; i++) { %>&#9734;<% } %>
                                </p>
                                <p class="review-comment"><%= review.comment %></p>

                                <% if (currentUser && review.owner && review.owner.equals(currentUser._id)) { %>
                                    <div class="review-actions">
                                        <button type="button" class="btn small" onclick="document.getElementById('view-<%= review._id %>').style.display='none'; document.getElementById('edit-<%= review._id %>').style.display='block';">Edit</button>
                                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <button class="btn danger small" type="submit">Delete</button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>

                            <% if (currentUser && review.owner && review.owner.equals(currentUser._id)) { %>
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT" id="edit-<%= review._id %>" style="display:none;">
                                    <div class="star-rating">
                                        <input type="radio" id="editstar5-<%= review._id %>" name="review[rating]" value="5" <%= review.rating === 5 ? 'checked' : '' %>>
                                        <label for="editstar5-<%= review._id %>">&#9733;</label>
                                        <input type="radio" id="editstar4-<%= review._id %>" name="review[rating]" value="4" <%= review.rating === 4 ? 'checked' : '' %>>
                                        <label for="editstar4-<%= review._id %>">&#9733;</label>
                                        <input type="radio" id="editstar3-<%= review._id %>" name="review[rating]" value="3" <%= review.rating === 3 ? 'checked' : '' %>>
                                        <label for="editstar3-<%= review._id %>">&#9733;</label>
                                        <input type="radio" id="editstar2-<%= review._id %>" name="review[rating]" value="2" <%= review.rating === 2 ? 'checked' : '' %>>
                                        <label for="editstar2-<%= review._id %>">&#9733;</label>
                                        <input type="radio" id="editstar1-<%= review._id %>" name="review[rating]" value="1" <%= review.rating === 1 ? 'checked' : '' %>>
                                        <label for="editstar1-<%= review._id %>">&#9733;</label>
                                    </div>
                                    <div class="form-group">
                                        <textarea name="review[comment]" rows="3"><%= review.comment %></textarea>
                                    </div>
                                    <button class="btn" type="submit">Save Changes</button>
                                </form>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="muted">No reviews yet. Be the first to review this listing!</p>
            <% } %>
        </div>
        <% } %>

        <a class="text-link" href="/listings">Back to all listings</a>
    </div>
</article>
