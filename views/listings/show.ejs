<% layout('layouts/boilerplate') %>
<article class="show-page">
    <img class="show-image"
        src="<%= listing.image.url %>" 
        alt="<%= listing.title %>" 
    >

    <div class="show-content">
        <h1><%= listing.title %></h1>
    <p><%= listing.description %></p>
        <p class="price">&#8377; <%= listing.price.toLocaleString('en-IN') %> per night</p>
        <p class="muted"><%= listing.location %>, <%= listing.country %></p>

        <div class="actions">
            <a class="btn" href="/listings/<%= listing._id %>/edit">Edit this listing</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn danger" type="submit">Delete this listing</button>
            </form>
        </div>

        <a class="text-link" href="/listings">Back to all listings</a>
    </div>
</article>
