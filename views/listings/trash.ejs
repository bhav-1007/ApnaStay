<% layout('layouts/boilerplate') %>

<div class="page-heading">
    <div>
        <h1>Trash</h1>
        <p>Listings here can be restored or permanently deleted.</p>
    </div>
</div>

<% if (trashedListings.length > 0) { %>
    <ul class="listing-grid">
        <% trashedListings.forEach(listing => { %>
            <li class="listing-card">
                <a href="/listings/<%= listing._id %>">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                </a>
                <div class="listing-card-body">
                    <h2><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h2>
                    <p class="muted">
                        Deleted <%= listing.deletedAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </p>

                    <div class="actions">
                        <form method="POST" action="/listings/<%= listing._id %>/restore">
                            <button class="btn" type="submit">Restore</button>
                        </form>
                        <form method="POST" action="/listings/<%= listing._id %>/permanent?_method=DELETE" class="needs-confirm-delete-permanent">
                            <button class="btn danger" type="submit">Delete Forever</button>
                        </form>
                    </div>
                </div>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p class="muted">Trash is empty.</p>
<% } %>

<a class="text-link" href="/listings">Back to all listings</a>
