<% layout('layouts/boilerplate') %>

<div class="page-heading">
    <div>
        <h1>My Shift Requests</h1>
        <p>All peak-hour staffing requests posted by your business.</p>
    </div>
</div>

<% if (myListings.length > 0) { %>
    <ul class="listing-grid">
        <% myListings.forEach(listing => { %>
            <li class="listing-card">
                <a href="/listings/<%= listing._id %>">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                </a>
                <div class="listing-card-body">
                    <h2><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h2>
                    <p><%= listing.description %></p>
                    <p class="price">&#8377; <%= listing.price.toLocaleString('en-IN') %> / hour</p>
                </div>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p class="muted">You have not posted any shifts yet.</p>
    <a class="btn" href="/listings/new">Post your first shift</a>
<% } %>
