<% layout('layouts/boilerplate') %>

<section class="container mt-4">
  <div class="form-panel">
    <h1>Create New Listing</h1>

    <form method="POST" action="/listings" enctype="multipart/form-data">
      <div>
        <label for="title">Title</label>
        <input type="text" id="title" name="listing[title]" placeholder="Title" required>
      </div>

      <div>
        <label for="description">Description</label>
        <textarea id="description" name="listing[description]" placeholder="Description" required></textarea>
      </div>

      <div>
        <label for="image">Upload Image</label>
        <input type="file" id="image" name="listing[image]" accept="image/*">
      </div>

      <div>
        <label for="price">Price (per night)</label>
        <input type="number" id="price" name="listing[price]" placeholder="Price" required min="0">
      </div>

      <div style="position:relative;">
        <label for="location-search">Location</label>
        <input type="text" id="location-search" placeholder="Start typing an address or city..." autocomplete="off" required>
        <div id="suggestions" class="location-suggestions"></div>
        <p class="muted" id="location-confirm" style="margin-top:6px; display:none;">
          <i class="fa-solid fa-circle-check"></i> Location confirmed: <span id="location-confirm-text"></span>
        </p>
      </div>

      <!-- Hidden fields actually submitted to the server -->
      <input type="hidden" id="location" name="listing[location]">
      <input type="hidden" id="country" name="listing[country]">
      <input type="hidden" id="lat" name="listing[lat]">
      <input type="hidden" id="lng" name="listing[lng]">

      <div class="col-12">
        <button class="btn" type="submit">Create Listing</button>
      </div>
    </form>
  </div>
</section>

<script>
  (function () {
    const searchInput = document.getElementById('location-search');
    const suggestionsBox = document.getElementById('suggestions');
    const locationInput = document.getElementById('location');
    const countryInput = document.getElementById('country');
    const latInput = document.getElementById('lat');
    const lngInput = document.getElementById('lng');
    const confirmMsg = document.getElementById('location-confirm');
    const confirmText = document.getElementById('location-confirm-text');

    let debounceTimer;

    searchInput.addEventListener('input', () => {
      // typing again invalidates any previously confirmed selection
      locationInput.value = '';
      countryInput.value = '';
      latInput.value = '';
      lngInput.value = '';
      confirmMsg.style.display = 'none';

      clearTimeout(debounceTimer);
      const query = searchInput.value.trim();
      if (query.length < 3) {
        suggestionsBox.innerHTML = '';
        return;
      }

      debounceTimer = setTimeout(async () => {
        try {
          const url = `https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&limit=5&q=${encodeURIComponent(query)}`;
          const res = await fetch(url);
          const data = await res.json();
          renderSuggestions(data);
        } catch (err) {
          suggestionsBox.innerHTML = '<div class="suggestion-item muted">Search failed, try again.</div>';
        }
      }, 400);
    });

    function renderSuggestions(results) {
      suggestionsBox.innerHTML = '';
      if (!results.length) {
        suggestionsBox.innerHTML = '<div class="suggestion-item muted">No matches found.</div>';
        return;
      }
      results.forEach((place) => {
        const item = document.createElement('div');
        item.className = 'suggestion-item';
        item.textContent = place.display_name;
        item.addEventListener('click', () => {
          searchInput.value = place.display_name;
          locationInput.value = place.display_name;
          countryInput.value = (place.address && place.address.country) || '';
          latInput.value = place.lat;
          lngInput.value = place.lon;
          suggestionsBox.innerHTML = '';
          confirmText.textContent = place.display_name;
          confirmMsg.style.display = 'block';
        });
        suggestionsBox.appendChild(item);
      });
    }

    // close suggestions if clicking elsewhere
    document.addEventListener('click', (e) => {
      if (!suggestionsBox.contains(e.target) && e.target !== searchInput) {
        suggestionsBox.innerHTML = '';
      }
    });

    // prevent submitting without a confirmed selection
    searchInput.closest('form').addEventListener('submit', (e) => {
      if (!latInput.value || !lngInput.value) {
        e.preventDefault();
        alert('Please select a location from the suggestions list.');
        searchInput.focus();
      }
    });
  })();
</script>
