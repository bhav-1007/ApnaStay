<% layout('layouts/boilerplate') %>
<section class="form-panel">
  <h1>Edit Listing</h1>

  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
    <label>
      Title
      <input type="text" name="listing[title]" value="<%= listing.title %>" placeholder="Title" required>
    </label>

    <label>
      Description
      <textarea name="listing[description]" placeholder="Description" required><%= listing.description %></textarea>
    </label>

    <label>
      Image URL
      <input type="text" name="listing[image][url]" value="<%= listing.image.url %>" placeholder="Image URL">
    </label>

    <label>
      Price
      <input type="number" name="listing[price]" value="<%= listing.price %>" placeholder="Price" required>
    </label>

    <label>
      Location
      <input type="text" name="listing[location]" value="<%= listing.location %>" placeholder="Location" required>
    </label>

    <label>
      Country
      <input type="text" name="listing[country]" value="<%= listing.country %>" placeholder="Country" required>
    </label>

    <button class="btn" type="submit">Update Listing</button>
  </form>

  <a class="text-link" href="/listings/<%= listing._id %>">Back to listing</a>
</section>
