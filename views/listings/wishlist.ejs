<% layout('layouts/boilerplate') %>

<div class="page-heading">
    <div>
        <h1>My Wishlist</h1>
        <p>Listings you've saved for later.</p>
    </div>
</div>

<% if (wishlistListings.length > 0) { %>
    <ul class="listing-grid">
        <% wishlistListings.forEach(listing => { %>
            <li class="listing-card">
                <a href="/listings/<%= listing._id %>">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                </a>
                <div class="listing-card-body">
                    <h2><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h2>
                    <p><%= listing.description %></p>
                    <p class="price">&#8377; <%= listing.price.toLocaleString('en-IN') %> / night</p>
                </div>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p class="muted">Your wishlist is empty. Browse listings and tap the heart to save them here.</p>
    <a class="btn" href="/listings">Browse listings</a>
<% } %>
