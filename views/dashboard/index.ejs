<% layout('layouts/boilerplate') %>

<div class="page-heading">
    <div>
        <h1>Dashboard</h1>
        <p>Track shift requests, accepted workers, fulfillment, and upcoming check-ins.</p>
    </div>
    <a class="btn" href="/listings/new">Post Shift</a>
</div>

<section class="stats-grid">
    <div class="stat-card">
        <span>Total Shift Requests</span>
        <strong><%= stats.totalListings %></strong>
    </div>
    <div class="stat-card">
        <span>Accepted Shifts</span>
        <strong><%= stats.totalBookings %></strong>
    </div>
    <div class="stat-card">
        <span>Upcoming Check-ins</span>
        <strong><%= stats.upcomingCheckIns %></strong>
    </div>
</section>

<section class="dashboard-section">
    <div class="section-heading">
        <h2>Your Shift Requests</h2>
        <a class="text-link" href="/listings/my">Manage shifts</a>
    </div>

    <% if (myListings.length > 0) { %>
        <ul class="dashboard-listings">
            <% myListings.forEach(listing => { %>
                <li>
                    <a href="/listings/<%= listing._id %>"><%= listing.title %></a>
                    <span>&#8377; <%= listing.price.toLocaleString('en-IN') %> / hour</span>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p class="muted">You have not posted any shifts yet.</p>
    <% } %>
</section>

<section class="dashboard-section">
    <div class="section-heading">
        <h2>Accepted Workers</h2>
    </div>

    <% if (bookings.length > 0) { %>
        <div class="table-wrap">
            <table class="dashboard-table">
                <thead>
                    <tr>
                        <th>Shift</th>
                        <th>Worker</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Hours</th>
                        <th>Payout</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach(booking => { %>
                        <tr>
                            <td>
                                <% if (booking.listing) { %>
                                    <a href="/listings/<%= booking.listing._id %>"><%= booking.listing.title %></a>
                                <% } else { %>
                                    Shift unavailable
                                <% } %>
                            </td>
                            <td><%= booking.guest ? booking.guest.username : "Worker unavailable" %></td>
                            <td><%= booking.checkIn.toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' }) %></td>
                            <td><%= booking.checkOut.toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' }) %></td>
                            <td><%= booking.totalNights %></td>
                            <td>&#8377; <%= booking.totalPrice.toLocaleString('en-IN') %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <p class="muted">No workers have accepted your shifts yet.</p>
    <% } %>
</section>
