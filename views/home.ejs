<% layout('layouts/boilerplate') %>

<section class="hero peak-hero">
  <div class="hero-copy">
    <p class="eyebrow">Real-time staffing for peak-hour demand</p>
    <h1 class="hero-title">Making labor as flexible as demand itself.</h1>
    <p class="hero-subtitle">PeakShift connects businesses that need extra hands for 2-4 hour rushes with verified workers looking for flexible earning opportunities.</p>
    <div class="hero-actions">
      <a class="btn hero-cta" href="/listings">Find Open Shifts</a>
      <a class="btn secondary" href="/listings/new">Post a Shift</a>
    </div>
  </div>
  <div class="hero-panel" aria-label="Live staffing preview">
    <div class="live-shift-card">
      <span class="status-pill">Live match</span>
      <h2>Cloud kitchen dinner rush</h2>
      <p>2 packers and 1 helper needed from 7 PM-10 PM near Indiranagar.</p>
      <div class="shift-metrics">
        <span><strong>15</strong> matched workers</span>
        <span><strong>3 km</strong> radius</span>
        <span><strong>&#8377;150</strong> / hour</span>
      </div>
    </div>
  </div>
</section>

<section class="featured-section">
  <div class="section-heading-inline">
    <h2 class="section-title">Open Peak Shifts</h2>
    <a class="text-link" href="/listings">Browse all</a>
  </div>

  <% if (featuredListings && featuredListings.length > 0) { %>
  <div class="featured-grid">
    <% featuredListings.forEach(listing => { %>
      <a class="featured-card" href="/listings/<%= listing._id %>">
        <img class="featured-image" src="<%= listing.image.url %>" alt="<%= listing.title %>">
        <div class="featured-info">
          <h3 class="featured-title"><%= listing.title %></h3>
          <p class="featured-location"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
          <p class="featured-price">&#8377; <%= listing.price.toLocaleString('en-IN') %> <span class="price-unit">per hour</span></p>
        </div>
      </a>
    <% }) %>
  </div>
  <% } else { %>
    <p class="muted" style="padding:0 20px 28px;">No shifts are live yet. Post the first peak-hour request.</p>
  <% } %>
</section>

<section class="how-it-works">
  <h2 class="section-title">How PeakShift Works</h2>
  <div class="steps-grid">
    <div class="step-card">
      <div class="step-number">1</div>
      <h3>Create a shift</h3>
      <p class="muted">Businesses post role, location, pay, timing, and worker count for a short demand spike.</p>
    </div>
    <div class="step-card">
      <div class="step-number">2</div>
      <h3>Match verified workers</h3>
      <p class="muted">Workers discover nearby opportunities by availability, skill tags, and trust history.</p>
    </div>
    <div class="step-card">
      <div class="step-number">3</div>
      <h3>Check in and get paid</h3>
      <p class="muted">GPS and selfie check-in confirm attendance before automatic post-shift settlement.</p>
    </div>
  </div>
</section>

<section class="market-section">
  <h2 class="section-title">Built for recurring local rushes</h2>
  <div class="market-grid">
    <span>Restaurants and QSRs</span>
    <span>Cloud kitchens</span>
    <span>Retail stores</span>
    <span>Pharmacies</span>
    <span>Multiplex cinemas</span>
    <span>Events</span>
  </div>
</section>
