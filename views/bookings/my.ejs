<% layout('layouts/boilerplate') %>

<div class="page-heading">
    <div>
        <h1>My Bookings</h1>
        <p>Your confirmed and cancelled ApnaStay reservations.</p>
    </div>
    <a class="btn" href="/listings">Find a Stay</a>
</div>

<% if (bookings.length > 0) { %>
    <div class="booking-list">
        <% bookings.forEach(booking => { %>
            <article class="booking-card">
                <% if (booking.listing && booking.listing.image && booking.listing.image.url) { %>
                    <a href="/listings/<%= booking.listing._id %>">
                        <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                    </a>
                <% } %>
                <div class="booking-card-body">
                    <div class="booking-card-head">
                        <div>
                            <h2>
                                <% if (booking.listing) { %>
                                    <a href="/listings/<%= booking.listing._id %>"><%= booking.listing.title %></a>
                                <% } else { %>
                                    Listing unavailable
                                <% } %>
                            </h2>
                            <% if (booking.listing) { %>
                                <p class="muted"><i class="fa-solid fa-location-dot"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                            <% } %>
                        </div>
                        <span class="status-pill <%= booking.status === 'cancelled' ? 'cancelled' : '' %>">
                            <%= booking.status %>
                        </span>
                    </div>

                    <div class="booking-facts">
                        <span><i class="fa-solid fa-calendar-day"></i> <%= booking.checkIn.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                        <span><i class="fa-solid fa-calendar-check"></i> <%= booking.checkOut.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                        <span><i class="fa-solid fa-moon"></i> <%= booking.totalNights %> night<%= booking.totalNights !== 1 ? "s" : "" %></span>
                        <span><i class="fa-solid fa-indian-rupee-sign"></i> <%= booking.totalPrice.toLocaleString('en-IN') %></span>
                    </div>

                    <% if (booking.status === "confirmed") { %>
                        <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE">
                            <button class="btn danger small" type="submit">Cancel Booking</button>
                        </form>
                    <% } %>
                </div>
            </article>
        <% }) %>
    </div>
<% } else { %>
    <p class="muted">You do not have any bookings yet.</p>
    <a class="btn" href="/listings">Explore listings</a>
<% } %>
