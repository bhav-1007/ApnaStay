<section class="booking-panel">
    <div>
        <h3>Book this stay</h3>
        <p class="muted">&#8377; <%= listing.price.toLocaleString('en-IN') %> per night, auto-confirmed instantly.</p>
    </div>

    <% if (!currentUser) { %>
        <a class="btn" href="/login">Login to Book</a>
    <% } else if (listing.owner && listing.owner._id.equals(currentUser._id)) { %>
        <p class="muted">This is your listing, so guests will see booking options here.</p>
    <% } else { %>
        <form method="POST" action="/listings/<%= listing._id %>/bookings" class="booking-form">
            <div class="booking-date-grid">
                <label for="checkIn">
                    Check-in
                    <input type="date" id="checkIn" name="checkIn" required>
                </label>
                <label for="checkOut">
                    Check-out
                    <input type="date" id="checkOut" name="checkOut" required>
                </label>
            </div>
            <button class="btn" type="submit">
                <i class="fa-solid fa-calendar-check"></i>
                Confirm Booking
            </button>
        </form>
    <% } %>
</section>
