<section class="booking-panel">
    <div>
        <h3>Accept this shift</h3>
        <p class="muted">&#8377; <%= listing.price.toLocaleString('en-IN') %> per hour, verified check-in and post-shift settlement.</p>
    </div>

    <% if (!currentUser) { %>
        <a class="btn" href="/login">Login to Accept</a>
    <% } else if (listing.owner && listing.owner._id.equals(currentUser._id)) { %>
        <p class="muted">This is your shift request, so workers will see acceptance options here.</p>
    <% } else { %>
        <form method="POST" action="/listings/<%= listing._id %>/bookings" class="booking-form">
            <div class="booking-date-grid">
                <label for="startAt">
                    Shift start
                    <input type="datetime-local" id="startAt" name="startAt" required>
                </label>
                <label for="endAt">
                    Shift end
                    <input type="datetime-local" id="endAt" name="endAt" required>
                </label>
            </div>
            <button class="btn" type="submit">
                <i class="fa-solid fa-calendar-check"></i>
                Accept Shift
            </button>
        </form>
    <% } %>
</section>
